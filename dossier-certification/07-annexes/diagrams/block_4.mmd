flowchart LR
  %% --- Acteurs ---
  V([Visiteur])
  U([Utilisateur])
  A([Auteur de contenu])
  PG([Propriétaire de groupe])
  OE([Organisateur d'événement])

  U -. hérite .-> A
  U -. hérite .-> PG
  U -. hérite .-> OE

  %% --- Authentification ---
  subgraph AUTH["Authentification"]
    UC_register(S'inscrire)
    UC_login(Se connecter)
    UC_google(Se connecter via Google)
    UC_logout(Se déconnecter)
  end
  V --> UC_register
  V --> UC_login
  V --> UC_google
  U --> UC_logout

  %% --- Profil ---
  subgraph PROFILE["Profil et Paramètres"]
    UC_viewMe(Consulter mon profil)
    UC_editMe(Modifier mon profil)
    UC_settings(Modifier mes paramètres)
    UC_viewProfile(Consulter un profil)
  end
  U --> UC_viewMe
  U --> UC_editMe
  U --> UC_settings
  U --> UC_viewProfile

  %% --- Publications ---
  subgraph FEED["Publications"]
    UC_feed(Consulter le feed)
    UC_reels(Consulter les reels)
    UC_post(Publier un post)
    UC_viewPost(Voir un post)
    UC_postsProfile(Voir les posts d'un profil)
    UC_comment(Commenter un post)
    UC_react(Réagir à un contenu)
    UC_unreact(Retirer une réaction)
    UC_story(Publier une story)
    UC_viewStories(Voir les stories)
  end
  U --> UC_feed
  U --> UC_reels
  U --> UC_post
  U --> UC_viewPost
  U --> UC_postsProfile
  U --> UC_comment
  U --> UC_react
  U --> UC_unreact
  U --> UC_story
  U --> UC_viewStories

  %% --- Recherche ---
  subgraph SEARCH["Recherche"]
    UC_search(Rechercher contenu et utilisateurs)
    UC_searchUsers(Rechercher des utilisateurs)
  end
  U --> UC_search
  U --> UC_searchUsers

  %% --- Relations sociales ---
  subgraph SOCIAL["Relations sociales"]
    UC_friendReq(Envoyer une demande d'amitié)
    UC_friendAnswer(Accepter ou refuser une demande)
    UC_friendList(Lister mes demandes reçues)
    UC_friendStatus(Voir le statut avec un user)
    UC_follow(Suivre un utilisateur)
    UC_unfollow(Se désabonner)
    UC_followers(Lister followers et following)
    UC_followStats(Voir stats follow)
  end
  U --> UC_friendReq
  U --> UC_friendAnswer
  U --> UC_friendList
  U --> UC_friendStatus
  U --> UC_follow
  U --> UC_unfollow
  U --> UC_followers
  U --> UC_followStats

  %% --- Messagerie ---
  subgraph CHAT["Messagerie temps réel"]
    UC_listConv(Lister mes conversations)
    UC_listMsg(Lister les messages)
    UC_send(Envoyer un message)
    UC_listenSSE(Recevoir les messages temps réel)
    UC_typing(Signaler que je tape)
    UC_seen(Marquer comme lu)
    UC_unread(Compteur de non-lus)
  end
  U --> UC_listConv
  U --> UC_listMsg
  U --> UC_send
  U --> UC_listenSSE
  U --> UC_typing
  U --> UC_seen
  U --> UC_unread

  %% --- Groupes ---
  subgraph GROUPS["Groupes et Communautés"]
    UC_listGroups(Lister mes groupes)
    UC_createGroup(Créer un groupe)
    UC_viewGroup(Voir un groupe)
    UC_leaveGroup(Quitter un groupe)
    UC_joinReq(Demander à rejoindre un groupe)
    UC_acceptInvite(Accepter ou refuser une invitation)
    UC_listInvites(Lister les invitations reçues)
    UC_editGroup(Modifier un groupe)
    UC_deleteGroup(Supprimer un groupe)
    UC_inviteMember(Inviter un membre)
    UC_respondReq(Accepter ou refuser une demande d'adhésion)
    UC_removeMember(Retirer un membre)
  end
  U --> UC_listGroups
  U --> UC_createGroup
  U --> UC_viewGroup
  U --> UC_leaveGroup
  U --> UC_joinReq
  U --> UC_acceptInvite
  U --> UC_listInvites
  PG --> UC_editGroup
  PG --> UC_deleteGroup
  PG --> UC_inviteMember
  PG --> UC_respondReq
  PG --> UC_removeMember

  %% --- Événements ---
  subgraph EVENTS["Événements"]
    UC_listEvents(Lister les événements)
    UC_viewEvent(Voir un événement)
    UC_upcomingEvents(Voir les événements à venir)
    UC_createEvent(Créer un événement)
    UC_rsvp(Répondre à un événement)
    UC_unrsvp(Annuler ma réponse)
    UC_editEvent(Modifier un événement)
    UC_deleteEvent(Supprimer un événement)
  end
  U --> UC_listEvents
  U --> UC_viewEvent
  U --> UC_upcomingEvents
  U --> UC_createEvent
  U --> UC_rsvp
  U --> UC_unrsvp
  OE --> UC_editEvent
  OE --> UC_deleteEvent

  classDef actor fill:#ffe9b3,stroke:#b8860b,stroke-width:2px,color:#000;
  class V,U,A,PG,OE actor;