        <mxCell id="msg3" value="SET latest:chat:bob_id&lt;br&gt;&lt;font style='font-size:10px'&gt;{ content: 'Salut Bob', from: alice_id }&lt;br&gt;TTL 60s&lt;/font&gt;" style="edgeStyle=elbowEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#d6b656;fontColor=#1a1a2e;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
